# Optional override for the compiler API endpoint.
# If unset, the app falls back to packages/core/src/constants.ts (COMPILER_API_URL).
# Create a local apps/playground/.env to point at a different compiler
# (e.g. a local server or a fork). The file is git-ignored by the root
# .gitignore — the Railway URL is not a secret but it is environment-specific.
VITE_COMPILER_API_URL=https://agile-sparkle-production-83d3.up.railway.app

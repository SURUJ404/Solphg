{
  "name": "@solshift/monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "prepare": "npm run build -w @solshift/core -w @solshift/engine -w @solshift/shell -w @solshift/plugin-manager -w @solshift/integrations",
    "build": "npm run prepare && npm run build -w @solshift/playground",
    "dev": "npm run prepare && npm run dev -w @solshift/playground",
    "clean": "npm run --workspaces --if-present clean"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@solana/accounts": "^7.0.0",
    "@solana/addresses": "^7.0.0",
    "@solana/codecs-numbers": "^7.0.0",
    "@solana/instructions": "^7.0.0",
    "@solana/keys": "^7.0.0",
    "@solana/rpc": "^7.0.0",
    "@solana/rpc-types": "^7.0.0",
    "@solana/signers": "^7.0.0",
    "@solana/transactions": "^7.0.0",
    "@solana/web3.js": "^1.98.4"
  }
}
